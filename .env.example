# Supabase — variáveis server-only (sem NEXT_PUBLIC_)
# Copie para .env.local e preencha com os valores do projeto Supabase.

# URL do projeto (Settings → API)
SUPABASE_URL=https://your-project.supabase.co

# Chave anon — usada no servidor via @supabase/ssr (RLS continua valendo)
SUPABASE_ANON_KEY=your-anon-key

# Service role — SOMENTE rotas admin internas; nunca expor ao browser
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# URL pública do app (redirects OAuth, confirmação de e-mail, recuperação de senha)
# Desenvolvimento: http://localhost:3000
# Produção: https://seu-dominio.com
SITE_URL=http://localhost:3000

# --- Configuração no Supabase Dashboard ---
#
# 1. Authentication → Providers
#    - Email: habilitado (Confirm email ON para exigir confirmação)
#    - Google: habilitado + Client ID e Client Secret do Google Cloud
#
# 2. Authentication → URL Configuration
#    - Site URL: mesmo valor de SITE_URL acima
#    - Redirect URLs (adicionar todas):
#      http://localhost:3000/auth/callback
#      http://localhost:3000/auth/confirm
#      https://seu-dominio.com/auth/callback
#      https://seu-dominio.com/auth/confirm
#
# 3. Authentication → Email Templates → Confirm signup
#    Trocar link de confirmação para:
#    {{ .SiteURL }}/auth/confirm?token_hash={{ .TokenHash }}&type=email&next=/campanha
#
# 4. Authentication → Email Templates → Reset password
#    Trocar link para:
#    {{ .SiteURL }}/auth/confirm?token_hash={{ .TokenHash }}&type=recovery&next=/redefinir-senha
#
# 5. Google Cloud Console → OAuth client (Web)
#    - Authorized JavaScript origins: SITE_URL
#    - Authorized redirect URIs: copiar de Authentication → Providers → Google
