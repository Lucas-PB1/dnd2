# Supabase — variáveis server-only (sem NEXT_PUBLIC_)
# Copie para .env.local e preencha com os valores do projeto Supabase.

# URL do projeto (Dashboard → Connect → Project URL)
SUPABASE_URL=https://your-project.supabase.co

# Publishable key — substitui a legacy anon key (Dashboard → Connect → Publishable key)
# Formato: sb_publishable_...
SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# Secret key — substitui a legacy service_role; SOMENTE rotas admin internas
# Formato: sb_secret_... (Dashboard → Settings → API Keys → Secret keys)
SUPABASE_SECRET_KEY=your-secret-key

# URL pública do app (redirect OAuth)
# Desenvolvimento: http://localhost:3000
# Produção: https://seu-dominio.com
SITE_URL=http://localhost:3000

# --- Configuração no Supabase Dashboard (auth Google) ---
#
# 1. Authentication → Sign In / Providers
#    - Google: habilitado + Client ID e Client Secret do Google Cloud
#    - Email: pode desabilitar se usar só Google
#
# 2. Authentication → URL Configuration
#    - Site URL: mesmo valor de SITE_URL acima
#    - Redirect URLs:
#      http://localhost:3000/auth/callback
#      https://seu-dominio.com/auth/callback
#
# 3. Google Cloud Console → OAuth client (Web)
#    - Authorized JavaScript origins: SITE_URL
#    - Authorized redirect URIs: copiar de Authentication → Providers → Google
#      (formato: https://<project-ref>.supabase.co/auth/v1/callback)
